<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>SecureCodeHub — Security Topics</title>
    <style>
        /* Reset default browser margins and box sizing for consistent rendering */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Body styling with gradient background matching SecureCodeHub theme */
        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
            display: flex;
            height: 100vh;
            background: linear-gradient(145deg, #f0f4f8 0%, #e6edf4 100%);
        }

        /* Sidebar styling - deep blue/black theme */
        .sidebar {
            width: 280px;
            background: #0B2B3F;
            color: white;
            padding: 28px 20px;
            overflow-y: auto;
            box-shadow: 2px 0 12px rgba(0, 0, 0, 0.08);
        }

        /* Sidebar title with blue accent border */
        .sidebar h2 {
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 2px solid #1C7EB5;
            letter-spacing: -0.3px;
            color: white;
        }

        /* Home button styling - positioned at top of sidebar */
        .home-button {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 16px;
            margin-bottom: 24px;
            background: #1a4b6e;
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            width: 100%;
        }

        /* Home button hover effect */
        .home-button:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        /* Home button active/press effect */
        .home-button:active {
            transform: translateX(2px);
        }

        /* Home icon styling */
        .home-icon {
            font-size: 1.2rem;
        }

        /* Search bar styling */
        .search-container {
            margin-bottom: 20px;
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1rem;
            opacity: 0.7;
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            padding: 10px 12px 10px 36px;
            background: #1a4b6e;
            border: 1px solid #2c7cb6;
            border-radius: 12px;
            color: white;
            font-size: 0.9rem;
            font-family: inherit;
            outline: none;
            transition: all 0.2s ease;
        }

        .search-input::placeholder {
            color: #a0c4e0;
            opacity: 0.7;
        }

        .search-input:focus {
            border-color: #1C7EB5;
            background: #2c7cb6;
            box-shadow: 0 0 0 2px rgba(28, 126, 181, 0.3);
        }

        .clear-search {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            font-size: 1rem;
            padding: 0;
            display: none;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        .clear-search:hover {
            opacity: 1;
        }

        /* No results message */
        .no-results {
            text-align: center;
            color: #a0c4e0;
            padding: 20px;
            font-size: 0.9rem;
            font-style: italic;
        }

        /* Category section styling */
        .category-section {
            margin-bottom: 20px;
        }

        .category-title {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #8ab3cf;
            margin: 15px 0 8px 0;
            padding-left: 8px;
        }

        .category-title:first-of-type {
            margin-top: 0;
        }

        /* Topic selection button styling */
        .topic-btn {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 6px;
            background: #1a4b6e;
            color: #f0f7fc;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            text-align: left;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: inherit;
            transition: all 0.2s ease;
            position: relative;
        }

        /* Topic button hover effect */
        .topic-btn:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        /* Active/selected topic button styling */
        .topic-btn.active {
            background: #1C7EB5;
            color: white;
            border-left: 3px solid white;
            font-weight: 600;
        }

        /* Type badge inside topic button - dynamically colored based on type */
        .topic-type-badge {
            display: inline-block;
            font-size: 0.65rem;
            padding: 2px 6px;
            border-radius: 8px;
            margin-left: 8px;
            font-weight: 500;
            vertical-align: middle;
            background: #5a6e7a;
            color: white;
        }

        /* Main content area - white card style */
        .content {
            flex: 1;
            padding: 40px 48px;
            background: white;
            overflow-y: auto;
        }

        /* Topic title styling with blue left border */
        .title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 24px;
            color: #0B2B3F;
            letter-spacing: -0.02em;
            border-left: 4px solid #1C7EB5;
            padding-left: 20px;
        }

        /* Main content text styling */
        .content-text {
            font-size: 1.2rem;
            line-height: 1.7;
            color: #2c4a6e;
            margin-bottom: 28px;
            padding: 0 4px;
        }

        /* Image container styling - larger display area */
        .topic-image {
            margin: 20px 0 28px 0;
            text-align: center;
            background: #f8fafd;
            padding: 20px;
            border-radius: 16px;
        }

        /* Image styling with responsive sizing */
        .topic-image img {
            width: 100%;
            min-width: 300px;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            border: 2px solid #e2edf7;
        }

        /* Explanation section styling */
        .explanation {
            font-size: 1.2rem;
            line-height: 1.7;
            color: #1f3b4c;
            margin-bottom: 28px;
            padding: 20px 24px;
            background: #f8fafd;
            border-radius: 16px;
            border-left: 4px solid #1C7EB5;
        }

        /* Vulnerabilities section container */
        .vulnerabilities-section {
            margin-top: 20px;
            padding: 20px;
            background: #f0f4f8;
            border-radius: 16px;
        }

        /* Vulnerabilities section title */
        .vulnerabilities-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #0B2B3F;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Warning icon before vulnerabilities title */
        .vulnerabilities-title:before {
            content: "⚠️";
            font-size: 1.3rem;
        }

        /* List of vulnerabilities */
        .vulnerabilities-list {
            list-style: none;
            padding: 0;
        }

        /* Individual vulnerability item styling */
        .vulnerability-item {
            padding: 12px 16px;
            margin-bottom: 10px;
            background: white;
            border-radius: 12px;
            color: #2c4a6e;
            font-size: 0.95rem;
            border: 1px solid #dce5ec;
            transition: all 0.2s ease;
        }

        /* Vulnerability item hover effect */
        .vulnerability-item:hover {
            border-color: #1C7EB5;
            transform: translateX(4px);
            background: #ffffff;
        }

        /* Empty state styling */
        .empty {
            color: #7f8c9a;
            text-align: center;
            margin-top: 60px;
            font-size: 1rem;
        }

        /* Custom scrollbar for sidebar */
        .sidebar::-webkit-scrollbar {
            width: 5px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: #1c4057;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: #3b9bd5;
            border-radius: 10px;
        }

        /* Custom scrollbar for content area */
        .content::-webkit-scrollbar {
            width: 6px;
        }
        .content::-webkit-scrollbar-track {
            background: #e2e8f0;
        }
        .content::-webkit-scrollbar-thumb {
            background: #9bbdd2;
            border-radius: 10px;
        }

        /* Responsive adjustments for tablets */
        @media (max-width: 768px) {
            .content {
                padding: 24px 20px;
            }
            .title {
                font-size: 1.5rem;
            }
            .explanation {
                padding: 16px 20px;
                font-size: 0.95rem;
            }
            .topic-image img {
                min-width: 200px;
                max-height: 350px;
            }
            .topic-image {
                padding: 12px;
            }
            .topic-type-badge {
                font-size: 0.55rem;
                padding: 2px 4px;
            }
        }

        /* Larger image sizing for desktop screens */
        @media (min-width: 1200px) {
            .topic-image img {
                max-width: 80%;
                min-width: 400px;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar with home button and topic navigation -->
    <div class="sidebar">
        <a href="/" class="home-button">
            <span class="home-icon">🏠</span>
            <span>← Back to Home</span>
        </a>
        <h2>Security Topics</h2>

        <!-- Search bar -->
        <div class="search-container">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" class="search-input" placeholder="Search topics...">
            <button id="clearSearch" class="clear-search">✕</button>
        </div>

        <div id="topicList"></div>
    </div>

    <!-- Main content area where selected topic details are displayed -->
    <div class="content">
        <div id="main">
            <div class="title">Select a topic</div>
            <div class="content-text">Click a topic from the sidebar to learn about security vulnerabilities and defenses.</div>
        </div>
    </div>

    <script>
        // Array to store topics fetched from the server
        let topics = [];

        // Attempt to retrieve topics data injected from the server (EJS template)
        // Handles both array and single object formats for flexibility
        <% if (typeof locals.topics !== 'undefined') { %>
            topics = <%- JSON.stringify(locals.topics || []).replace(/<\//g, '<\\/') %>;
        <% } else if (typeof locals.topic !== 'undefined') { %>
            // If a single topic object is provided, wrap it in an array
            const topicData = <%- JSON.stringify(locals.topic) %>;
            if (Array.isArray(topicData)) {
                topics = topicData;
            } else if (topicData && typeof topicData === 'object') {
                topics = [topicData];
            } else {
                topics = [];
            }
        <% } %>

        // Debug log to verify topics data in browser console
        console.log('Topics received:', topics);

        /**
         * Escapes HTML special characters to prevent XSS attacks
         * @param {string} str - The string to escape
         * @returns {string} Escaped string safe for HTML insertion
         */
        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        /**
         * Generates a consistent color for a given type string
         * @param {string} type - The topic type
         * @returns {string} HSL color value
         */
        function getColorForType(type) {
            if (!type) return '#5a6e7a';

            // Generate a hash from the type string
            let hash = 0;
            for (let i = 0; i < type.length; i++) {
                hash = ((hash << 5) - hash) + type.charCodeAt(i);
                hash = hash & hash; // Convert to 32-bit integer
            }

            // Use the hash to generate a hue between 0 and 360
            // Use pastel/saturated range (30-60% saturation, 50-70% lightness for good contrast on dark background)
            const hue = Math.abs(hash % 360);
            return `hsl(${hue}, 55%, 45%)`;
        }

        /**
         * Checks if vulnerabilities exist and are non-empty
         * @param {Array} vulnerabilities - Array of vulnerability strings
         * @returns {boolean} True if vulnerabilities exist and have content
         */
        function hasVulnerabilities(vulnerabilities) {
            return vulnerabilities && Array.isArray(vulnerabilities) && vulnerabilities.length > 0;
        }

        /**
         * Renders the vulnerabilities array as HTML list items
         * @param {Array} vulnerabilities - Array of vulnerability strings
         * @returns {string} HTML markup for vulnerabilities section
         */
        function renderVulnerabilities(vulnerabilities) {
            let html = '<ul class="vulnerabilities-list">';
            vulnerabilities.forEach(vuln => {
                html += `<li class="vulnerability-item">⚠️ ${escapeHtml(vuln)}</li>`;
            });
            html += '</ul>';
            return html;
        }

        /**
         * Displays the selected topic in the main content area
         * Order of display: Title → Content → Image → Explanation → Vulnerabilities (if any)
         * @param {Object} topic - The topic object containing all fields
         */
        function showTopic(topic) {
            if (!topic) {
                console.warn('showTopic called with no topic');
                return;
            }
            console.log('Showing topic:', topic);

            // Start with the topic title
            let html = `<div class="title">${escapeHtml(topic.title)}</div>`;

            // 1. CONTENT section (main description of the topic)
            if (topic.content && topic.content.trim() !== '') {
                html += `<div class="content-text">${escapeHtml(topic.content).replace(/\n/g, '<br>')}</div>`;
            } else if (topic.description && topic.description.trim() !== '') {
                // Fallback to description field if content is not available
                html += `<div class="content-text">${escapeHtml(topic.description).replace(/\n/g, '<br>')}</div>`;
            }

            // 2. IMAGE section - displays visual representation of the topic
            if (topic.image && topic.image.trim() !== '') {
                html += `
                    <div class="topic-image">
                        <img src="${escapeHtml(topic.image)}" alt="${escapeHtml(topic.title)}" onerror="this.style.display='none'; this.parentElement.style.display='none'">
                    </div>
                `;
            }

            // 3. EXPLANATION section - detailed explanatory text
            if (topic.explanation && topic.explanation.trim() !== '') {
                html += `<div class="explanation">📖 ${escapeHtml(topic.explanation).replace(/\n/g, '<br>')}</div>`;
            }

            // 4. VULNERABILITIES section - ONLY show if vulnerabilities exist
            if (hasVulnerabilities(topic.vulnerabilities)) {
                html += `
                    <div class="vulnerabilities-section">
                        <div class="vulnerabilities-title">Associated Vulnerabilities</div>
                        ${renderVulnerabilities(topic.vulnerabilities)}
                    </div>
                `;
            }

            // Insert the generated HTML into the main content area
            document.getElementById('main').innerHTML = html;

            // Update the active state of sidebar buttons
            document.querySelectorAll('.topic-btn').forEach(btn => {
                btn.classList.remove('active');
                if (parseInt(btn.dataset.id) === topic.id) {
                    btn.classList.add('active');
                }
            });
        }

        /**
         * Creates a button element for a topic
         * @param {Object} topic - The topic object
         * @returns {HTMLElement} Button element
         */
        function createTopicButton(topic) {
            const btn = document.createElement('button');
            btn.className = 'topic-btn';

            // Add title text
            const titleSpan = document.createElement('span');
            titleSpan.textContent = topic.title || 'Untitled';
            btn.appendChild(titleSpan);

            // Add type badge if type exists
            if (topic.type) {
                const badge = document.createElement('span');
                badge.className = 'topic-type-badge';
                badge.textContent = topic.type;
                // Apply dynamic color based on the type string
                badge.style.backgroundColor = getColorForType(topic.type);
                btn.appendChild(badge);
            }

            btn.setAttribute('data-id', topic.id);

            // Add click event listener that displays the selected topic
            btn.addEventListener('click', (function(t) {
                return function() { showTopic(t); };
            })(topic));

            return btn;
        }

        /**
         * Builds the sidebar with clickable topic buttons grouped by type based on search filter
         * @param {string} searchTerm - Optional term to filter topics
         */
        function buildSidebar(searchTerm = '') {
            const container = document.getElementById('topicList');

            // Filter topics based on search term
            let filteredTopics = topics;
            if (searchTerm && searchTerm.trim() !== '') {
                const term = searchTerm.toLowerCase().trim();
                filteredTopics = topics.filter(topic =>
                    topic.title && topic.title.toLowerCase().includes(term)
                );
            }

            // Handle case when no topics are available
            if (!topics || topics.length === 0) {
                container.innerHTML = '<div style="color:#95a5a6;">No topics found</div>';
                return;
            }

            // Handle no search results
            if (filteredTopics.length === 0) {
                container.innerHTML = '<div class="no-results">No matching topics found</div>';
                return;
            }

            // Clear any existing content
            container.innerHTML = '';

            // If search is active, show flat list without categories
            if (searchTerm && searchTerm.trim() !== '') {
                for (let i = 0; i < filteredTopics.length; i++) {
                    const t = filteredTopics[i];
                    const btn = createTopicButton(t);
                    container.appendChild(btn);
                }
                if (filteredTopics.length > 0) {
                    showTopic(filteredTopics[0]);
                }
                return;
            }

            // Group topics by type for categorized display
            const groupedTopics = {};

            // Group topics by their type (use 'Uncategorized' for topics without a type)
            for (let i = 0; i < filteredTopics.length; i++) {
                const topic = filteredTopics[i];
                const type = topic.type || 'Uncategorized';

                if (!groupedTopics[type]) {
                    groupedTopics[type] = [];
                }
                groupedTopics[type].push(topic);
            }

            // Sort types alphabetically
            const sortedTypes = Object.keys(groupedTopics).sort();

            // Create category sections
            let firstTopicShown = false;
            for (let typeIndex = 0; typeIndex < sortedTypes.length; typeIndex++) {
                const typeName = sortedTypes[typeIndex];
                const topicsInType = groupedTopics[typeName];

                // Add category title
                const categoryDiv = document.createElement('div');
                categoryDiv.className = 'category-section';

                const categoryTitle = document.createElement('div');
                categoryTitle.className = 'category-title';
                categoryTitle.textContent = typeName;
                categoryDiv.appendChild(categoryTitle);

                // Add buttons for each topic in this category
                for (let i = 0; i < topicsInType.length; i++) {
                    const topic = topicsInType[i];
                    const btn = createTopicButton(topic);
                    categoryDiv.appendChild(btn);
                }

                container.appendChild(categoryDiv);

                // Show the first topic from the first category
                if (!firstTopicShown && topicsInType.length > 0) {
                    showTopic(topicsInType[0]);
                    firstTopicShown = true;
                }
            }
        }

        // Initialize the page by building the sidebar
        buildSidebar();

        // Set up search functionality
        const searchInput = document.getElementById('searchInput');
        const clearButton = document.getElementById('clearSearch');

        // Handle search input
        searchInput.addEventListener('input', function(e) {
            const searchTerm = e.target.value;
            buildSidebar(searchTerm);

            // Show/hide clear button
            if (searchTerm) {
                clearButton.style.display = 'block';
            } else {
                clearButton.style.display = 'none';
            }
        });

        // Handle clear button click
        clearButton.addEventListener('click', function() {
            searchInput.value = '';
            buildSidebar('');
            clearButton.style.display = 'none';
            searchInput.focus();
        });
    </script>
</body>
</html>
