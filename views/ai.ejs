<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SecureCodeHub — AI Security Assistant</title>
        <style>
            /* Reset default browser margins and padding */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            /* Main page background with gradient matching SecureCodeHub theme */
            body {
                font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
                background: linear-gradient(145deg, #f0f4f8 0%, #e6edf4 100%);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 1.5rem;
            }

            /* Chat container card - white background with subtle shadow */
            .chat-container {
                width: 90%;
                max-width: 900px;
                height: 90vh;
                background: white;
                border-radius: 2rem;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
                display: flex;
                flex-direction: column;
                overflow: hidden;
                border: 1px solid rgba(28, 88, 122, 0.15);
            }

            /* Header section with dark blue theme */
            .chat-header {
                background: #0B2B3F;
                color: white;
                padding: 20px 24px;
                text-align: center;
                position: relative;
                border-bottom: 2px solid #1C7EB5;
            }

            /* Home button - positioned absolutely in header */
            .home-button {
                position: absolute;
                left: 24px;
                top: 50%;
                transform: translateY(-50%);
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 16px;
                background: #1a4b6e;
                color: white;
                text-decoration: none;
                border-radius: 10px;
                font-size: 0.85rem;
                font-weight: 500;
                transition: all 0.2s ease;
            }

            /* Hover effect for home button */
            .home-button:hover {
                background: #2c7cb6;
                transform: translateY(-50%) translateX(2px);
            }

            /* Home icon styling */
            .home-icon {
                font-size: 1rem;
            }

            /* Header title styling */
            .chat-header h1 {
                font-size: 1.5rem;
                margin-bottom: 5px;
                font-weight: 700;
            }

            /* Header subtitle */
            .chat-header p {
                font-size: 0.85rem;
                opacity: 0.85;
            }

            /* Scrollable message area */
            .chat-messages {
                flex: 1;
                overflow-y: auto;
                padding: 24px;
                display: flex;
                flex-direction: column;
                gap: 16px;
                background: #fafcfd;
            }

            /* Individual message container */
            .message {
                display: flex;
                gap: 12px;
                animation: fadeIn 0.3s ease-in;
            }

            /* Fade-in animation for new messages */
            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* User messages align to the right */
            .message.user {
                justify-content: flex-end;
            }

            /* Message bubble styling */
            .message-content {
                max-width: 70%;
                padding: 12px 18px;
                border-radius: 18px;
                line-height: 1.5;
                word-wrap: break-word;
                font-size: 0.95rem;
            }

            /* User message bubble - blue gradient */
            .user .message-content {
                background: linear-gradient(135deg, #1C7EB5 0%, #0B2B3F 100%);
                color: white;
                border-bottom-right-radius: 4px;
            }

            /* Bot message bubble - light gray */
            .bot .message-content {
                background: #eef2f8;
                color: #1f3b4c;
                border-bottom-left-radius: 4px;
                border: 1px solid #dce5ec;
            }

            /* Avatar circle styling */
            .avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
                flex-shrink: 0;
            }

            /* User avatar appears after message (right side) */
            .user .avatar {
                background: #1C7EB5;
                color: white;
                order: 2;
            }

            /* Bot avatar */
            .bot .avatar {
                background: #0B2B3F;
                color: white;
            }

            /* Typing indicator - three bouncing dots */
            .typing-indicator {
                display: flex;
                padding: 12px 18px;
                background: #eef2f8;
                border-radius: 18px;
                width: fit-content;
                gap: 6px;
                border: 1px solid #dce5ec;
            }

            /* Individual dot styling */
            .typing-indicator span {
                display: inline-block;
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: #1C7EB5;
                animation: typing 1.4s infinite;
            }

            /* Staggered animation delays for each dot */
            .typing-indicator span:nth-child(2) {
                animation-delay: 0.2s;
            }
            .typing-indicator span:nth-child(3) {
                animation-delay: 0.4s;
            }

            /* Bouncing animation for typing indicator */
            @keyframes typing {
                0%,
                60%,
                100% {
                    transform: translateY(0);
                    opacity: 0.5;
                }
                30% {
                    transform: translateY(-10px);
                    opacity: 1;
                }
            }

            /* Input area container */
            .chat-input-container {
                padding: 20px 24px;
                border-top: 1px solid #e2edf7;
                display: flex;
                gap: 12px;
                background: white;
            }

            /* Text input field */
            .chat-input {
                flex: 1;
                padding: 12px 18px;
                border: 2px solid #dce5ec;
                border-radius: 30px;
                font-size: 0.95rem;
                font-family: inherit;
                outline: none;
                transition: all 0.3s;
                background: white;
                color: #1f3b4c;
            }

            /* Input focus state - blue glow effect */
            .chat-input:focus {
                border-color: #1C7EB5;
                box-shadow: 0 0 0 3px rgba(28, 126, 181, 0.1);
            }

            /* Send button styling */
            .send-button {
                padding: 12px 28px;
                background: #0B2B3F;
                color: white;
                border: none;
                border-radius: 30px;
                cursor: pointer;
                font-size: 0.95rem;
                font-weight: 600;
                font-family: inherit;
                transition: all 0.2s ease;
            }

            /* Send button hover effect */
            .send-button:hover {
                background: #1C7EB5;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(28, 126, 181, 0.3);
            }

            /* Send button active/press effect */
            .send-button:active {
                transform: translateY(0);
            }

            /* Disabled send button state */
            .send-button:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
            }

            /* Custom scrollbar for messages area */
            .chat-messages::-webkit-scrollbar {
                width: 6px;
            }
            .chat-messages::-webkit-scrollbar-track {
                background: #e2e8f0;
                border-radius: 10px;
            }
            .chat-messages::-webkit-scrollbar-thumb {
                background: #9bbdd2;
                border-radius: 10px;
            }

            /* Responsive styles for mobile devices */
            @media (max-width: 600px) {
                body {
                    padding: 0.5rem;
                }
                .message-content {
                    max-width: 85%;
                }
                .chat-container {
                    width: 100%;
                    height: 95vh;
                    border-radius: 1rem;
                }
                .chat-header {
                    padding: 16px 20px;
                }
                /* Hide "Home" text on mobile, show only icon */
                .home-button span:last-child {
                    display: none;
                }
                .home-button {
                    padding: 8px 12px;
                }
                .chat-header h1 {
                    font-size: 1.2rem;
                }
                .chat-messages {
                    padding: 16px;
                }
                .chat-input-container {
                    padding: 16px 20px;
                }
                .send-button {
                    padding: 12px 20px;
                }
            }
        </style>
    </head>
    <body>
        <div class="chat-container">
            <!-- Chat header with home button and title -->
            <div class="chat-header">
                <a href="/" class="home-button">
                    <span class="home-icon">🏠</span>
                    <span>Home</span>
                </a>
                <h1>🤖 AI Security Assistant</h1>
                <p>Powered by OpenRouter & Gemini — Ask me about cybersecurity!</p>
            </div>

            <!-- Container where messages will be displayed -->
            <div class="chat-messages" id="chatMessages">
                <!-- Initial welcome message from bot -->
                <div class="message bot">
                    <div class="avatar">🤖</div>
                    <div class="message-content">
                        Hello! I'm your AI security assistant. Ask me about vulnerabilities, secure coding practices, or any cybersecurity topic!
                    </div>
                </div>
            </div>

            <!-- Input area for user to type messages -->
            <div class="chat-input-container">
                <input
                    type="text"
                    id="messageInput"
                    class="chat-input"
                    placeholder="Ask about XSS, SQL injection, security best practices..."
                />
                <button id="sendButton" class="send-button">Send</button>
            </div>
        </div>

        <script>
            // Store conversation history for context
            let conversationHistory = [];

            // DOM element references
            const chatMessages = document.getElementById("chatMessages");
            const messageInput = document.getElementById("messageInput");
            const sendButton = document.getElementById("sendButton");

            /**
             * Adds a new message to the chat display
             * @param {string} role - Either "user" or "bot"
             * @param {string} content - Message text content
             */
            function addMessage(role, content) {
                const messageDiv = document.createElement("div");
                messageDiv.className = `message ${role}`;

                const avatar = document.createElement("div");
                avatar.className = "avatar";
                avatar.textContent = role === "user" ? "👤" : "🤖";

                const contentDiv = document.createElement("div");
                contentDiv.className = "message-content";
                contentDiv.textContent = content;

                messageDiv.appendChild(avatar);
                messageDiv.appendChild(contentDiv);

                chatMessages.appendChild(messageDiv);
                chatMessages.scrollTop = chatMessages.scrollHeight; // Auto-scroll to bottom
            }

            /**
             * Displays a typing indicator while waiting for AI response
             */
            function showTypingIndicator() {
                const typingDiv = document.createElement("div");
                typingDiv.className = "message bot";
                typingDiv.id = "typingIndicator";

                const avatar = document.createElement("div");
                avatar.className = "avatar";
                avatar.textContent = "🤖";

                const indicator = document.createElement("div");
                indicator.className = "typing-indicator";
                indicator.innerHTML = "<span></span><span></span><span></span>";

                typingDiv.appendChild(avatar);
                typingDiv.appendChild(indicator);

                chatMessages.appendChild(typingDiv);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }

            /**
             * Removes the typing indicator from the chat
             */
            function hideTypingIndicator() {
                const indicator = document.getElementById("typingIndicator");
                if (indicator) {
                    indicator.remove();
                }
            }

            /**
             * Sends user message to backend API and displays AI response
             */
            async function sendMessage() {
                const message = messageInput.value.trim();
                if (!message) return;

                // Clear input and disable button during request
                messageInput.value = "";
                sendButton.disabled = true;

                // Display user message in chat
                addMessage("user", message);
                // Store in conversation history
                conversationHistory.push({ role: "user", content: message });

                // Show that bot is "typing"
                showTypingIndicator();

                try {
                    // Send request to backend API endpoint
                    const response = await fetch(
                        "/api/chat",
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify({
                                message: message,
                                history: conversationHistory.slice(0, -1), // Send previous messages (excluding current)
                            }),
                        },
                    );

                    if (!response.ok) {
                        throw new Error("Failed to get response");
                    }

                    const data = await response.json();

                    hideTypingIndicator();

                    // Display bot response
                    addMessage("bot", data.reply);
                    // Store bot response in history
                    conversationHistory.push({
                        role: "assistant",
                        content: data.reply,
                    });

                    // Keep history manageable (last 20 messages)
                    if (conversationHistory.length > 20) {
                        conversationHistory = conversationHistory.slice(-20);
                    }
                } catch (error) {
                    hideTypingIndicator();
                    addMessage(
                        "bot",
                        "Sorry, I encountered an error. Please try again.",
                    );
                    console.error("Error:", error);
                } finally {
                    sendButton.disabled = false;
                    messageInput.focus(); // Return focus to input field
                }
            }

            // Event listener for send button click
            sendButton.addEventListener("click", sendMessage);

            // Event listener for Enter key press
            messageInput.addEventListener("keypress", (e) => {
                if (e.key === "Enter" && !sendButton.disabled) {
                    sendMessage();
                }
            });

            // Auto-focus input field when page loads
            messageInput.focus();
        </script>
    </body>
</html>
