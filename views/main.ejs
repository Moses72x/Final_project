<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>SecureCodeHub — Security Topics</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
            display: flex;
            height: 100vh;
            background: linear-gradient(145deg, #f0f4f8 0%, #e6edf4 100%);
        }

        /* SIDEBAR — deep blue/black theme */
        .sidebar {
            width: 280px;
            background: #0B2B3F;
            color: white;
            padding: 28px 20px;
            overflow-y: auto;
            box-shadow: 2px 0 12px rgba(0, 0, 0, 0.08);
        }

        .sidebar h2 {
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 2px solid #1C7EB5;
            letter-spacing: -0.3px;
            color: white;
        }

        .topic-btn {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 10px;
            background: #1a4b6e;
            color: #f0f7fc;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            text-align: left;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        .topic-btn:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        .topic-btn.active {
            background: #1C7EB5;
            color: white;
            border-left: 3px solid white;
            font-weight: 600;
        }

        /* MAIN CONTENT — white card style */
        .content {
            flex: 1;
            padding: 40px 48px;
            background: white;
            overflow-y: auto;
        }

        .title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 24px;
            color: #0B2B3F;
            letter-spacing: -0.02em;
            border-left: 4px solid #1C7EB5;
            padding-left: 20px;
        }

        /* Content text styling */
        .content-text {
            font-size: 1rem;
            line-height: 1.7;
            color: #2c4a6e;
            margin-bottom: 28px;
            padding: 0 4px;
        }

        /* Topic image styling — LARGER SIZE */
        .topic-image {
            margin: 20px 0 28px 0;
            text-align: center;
            background: #f8fafd;
            padding: 20px;
            border-radius: 16px;
        }

        .topic-image img {
            width: 100%;
            min-width: 300px;
            max-height: 500px;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            border: 2px solid #e2edf7;
        }

        /* Explanation section */
        .explanation {
            font-size: 1.05rem;
            line-height: 1.7;
            color: #1f3b4c;
            margin-bottom: 28px;
            padding: 20px 24px;
            background: #f8fafd;
            border-radius: 16px;
            border-left: 4px solid #1C7EB5;
        }

        /* Vulnerabilities section */
        .vulnerabilities-section {
            margin-top: 20px;
            padding: 20px;
            background: #f0f4f8;
            border-radius: 16px;
        }

        .vulnerabilities-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #0B2B3F;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .vulnerabilities-title:before {
            content: "⚠️";
            font-size: 1.3rem;
        }

        .vulnerabilities-list {
            list-style: none;
            padding: 0;
        }

        .vulnerability-item {
            padding: 12px 16px;
            margin-bottom: 10px;
            background: white;
            border-radius: 12px;
            color: #2c4a6e;
            font-size: 0.95rem;
            border: 1px solid #dce5ec;
            transition: all 0.2s ease;
        }

        .vulnerability-item:hover {
            border-color: #1C7EB5;
            transform: translateX(4px);
            background: #ffffff;
        }

        .no-vulnerabilities {
            color: #7f8c9a;
            font-style: italic;
            padding: 16px;
            text-align: center;
            background: white;
            border-radius: 12px;
        }

        .empty {
            color: #7f8c9a;
            text-align: center;
            margin-top: 60px;
            font-size: 1rem;
        }

        /* scrollbar styling */
        .sidebar::-webkit-scrollbar {
            width: 5px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: #1c4057;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: #3b9bd5;
            border-radius: 10px;
        }
        .content::-webkit-scrollbar {
            width: 6px;
        }
        .content::-webkit-scrollbar-track {
            background: #e2e8f0;
        }
        .content::-webkit-scrollbar-thumb {
            background: #9bbdd2;
            border-radius: 10px;
        }

        /* responsive adjustments */
        @media (max-width: 768px) {
            .content {
                padding: 24px 20px;
            }
            .title {
                font-size: 1.5rem;
            }
            .explanation {
                padding: 16px 20px;
                font-size: 0.95rem;
            }
            .topic-image img {
                min-width: 200px;
                max-height: 350px;
            }
            .topic-image {
                padding: 12px;
            }
        }

        @media (min-width: 1200px) {
            .topic-image img {
                max-width: 80%;
                min-width: 400px;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>Security Topics</h2>
        <div id="topicList"></div>
    </div>
    <div class="content">
        <div id="main">
            <div class="title">Select a topic</div>
            <div class="content-text">Click a topic from the sidebar to learn about security vulnerabilities and defenses.</div>
        </div>
    </div>

    <script>
        // Get the data from server - handle both 'topics' and 'topic' variable names
        let topics = [];

        // Try to get topics from locals.topics or locals.topic
        <% if (typeof locals.topics !== 'undefined') { %>
            topics = <%- JSON.stringify(locals.topics) %>;
        <% } else if (typeof locals.topic !== 'undefined') { %>
            // If it's a single object, wrap it in an array
            const topicData = <%- JSON.stringify(locals.topic) %>;
            if (Array.isArray(topicData)) {
                topics = topicData;
            } else if (topicData && typeof topicData === 'object') {
                topics = [topicData];
            } else {
                topics = [];
            }
        <% } %>

        // Debug: log to browser console
        console.log('Topics received:', topics);

        // Helper to escape HTML
        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // Helper to render vulnerabilities array
        function renderVulnerabilities(vulnerabilities) {
            if (!vulnerabilities || !Array.isArray(vulnerabilities) || vulnerabilities.length === 0) {
                return '<div class="no-vulnerabilities">No specific vulnerabilities listed for this topic yet.</div>';
            }

            let html = '<ul class="vulnerabilities-list">';
            vulnerabilities.forEach(vuln => {
                html += `<li class="vulnerability-item">⚠️ ${escapeHtml(vuln)}</li>`;
            });
            html += '</ul>';
            return html;
        }

        // Display a topic in order: content, image, explanation, vulnerabilities
        function showTopic(topic) {
            if (!topic) {
                console.warn('showTopic called with no topic');
                return;
            }
            console.log('Showing topic:', topic);

            let html = `<div class="title">${escapeHtml(topic.title)}</div>`;

            // 1. CONTENT section (original content/description)
            if (topic.content && topic.content.trim() !== '') {
                html += `<div class="content-text">${escapeHtml(topic.content).replace(/\n/g, '<br>')}</div>`;
            } else if (topic.description && topic.description.trim() !== '') {
                // Fallback to description if content doesn't exist
                html += `<div class="content-text">${escapeHtml(topic.description).replace(/\n/g, '<br>')}</div>`;
            }

            // 2. IMAGE section (larger display)
            if (topic.image && topic.image.trim() !== '') {
                html += `
                    <div class="topic-image">
                        <img src="${escapeHtml(topic.image)}" alt="${escapeHtml(topic.title)}" onerror="this.style.display='none'; this.parentElement.style.display='none'">
                    </div>
                `;
            }

            // 3. EXPLANATION section
            if (topic.explanation && topic.explanation.trim() !== '') {
                html += `<div class="explanation">📖 ${escapeHtml(topic.explanation).replace(/\n/g, '<br>')}</div>`;
            }

            // 4. VULNERABILITIES section
            html += `
                <div class="vulnerabilities-section">
                    <div class="vulnerabilities-title">Associated Vulnerabilities</div>
                    ${renderVulnerabilities(topic.vulnerabilities)}
                </div>
            `;

            document.getElementById('main').innerHTML = html;

            // Update active button
            document.querySelectorAll('.topic-btn').forEach(btn => {
                btn.classList.remove('active');
                if (parseInt(btn.dataset.id) === topic.id) {
                    btn.classList.add('active');
                }
            });
        }

        // Build sidebar buttons
        function buildSidebar() {
            const container = document.getElementById('topicList');
            if (!topics || topics.length === 0) {
                container.innerHTML = '<div style="color:#95a5a6;">No topics found</div>';
                return;
            }

            // Clear container
            container.innerHTML = '';

            // Create buttons
            for (let i = 0; i < topics.length; i++) {
                const t = topics[i];
                const btn = document.createElement('button');
                btn.className = 'topic-btn';
                btn.textContent = t.title || 'Untitled';
                btn.setAttribute('data-id', t.id);
                btn.addEventListener('click', (function(topic) {
                    return function() { showTopic(topic); };
                })(t));
                container.appendChild(btn);
            }

            // Show first topic by default
            if (topics.length > 0) {
                showTopic(topics[0]);
            }
        }

        // Run when page loads
        buildSidebar();
    </script>
</body>
</html>
