<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>SecureCodeHub — Vulnerability Examples</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            background: linear-gradient(145deg, #f0f4f8 0%, #e6edf4 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .vulnerability-app {
            display: flex;
            max-width: 1600px;
            width: 100%;
            flex: 1;
        }

        .sidebar {
            width: 300px;
            background: #0B2B3F;
            color: white;
            padding: 28px 20px;
            overflow-y: auto;
            box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.15);
            border: 1px solid rgba(28, 126, 181, 0.35);
            display: flex;
            flex-direction: column;
        }

        .home-button {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 16px;
            margin-bottom: 24px;
            background: #1a4b6e;
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            width: 100%;
        }

        .home-button:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        .home-button:active {
            transform: translateX(2px);
        }

        .home-icon {
            font-size: 1.2rem;
        }

        .sidebar h2 {
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 2px solid #1C7EB5;
            letter-spacing: -0.3px;
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar h2:before {
            content: "⚠️";
            font-size: 1.4rem;
        }

        .search-container {
            margin-bottom: 20px;
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1rem;
            opacity: 0.7;
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            padding: 10px 12px 10px 36px;
            background: #1a4b6e;
            border: 1px solid #2c7cb6;
            border-radius: 12px;
            color: white;
            font-size: 0.9rem;
            font-family: inherit;
            outline: none;
            transition: all 0.2s ease;
        }

        .search-input::placeholder {
            color: #a0c4e0;
            opacity: 0.7;
        }

        .search-input:focus {
            border-color: #1C7EB5;
            background: #2c7cb6;
            box-shadow: 0 0 0 2px rgba(28, 126, 181, 0.3);
        }

        .clear-search {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            font-size: 1rem;
            padding: 0;
            display: none;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        .clear-search:hover {
            opacity: 1;
        }

        .no-results {
            text-align: center;
            color: #a0c4e0;
            padding: 20px;
            font-size: 0.9rem;
            font-style: italic;
        }

        .category-section {
            margin-bottom: 20px;
        }

        .category-title {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #8ab3cf;
            margin: 15px 0 8px 0;
            padding-left: 8px;
        }

        .category-title:first-of-type {
            margin-top: 0;
        }

        .topic-btn {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 6px;
            background: #1a4b6e;
            color: #f0f7fc;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            text-align: left;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: inherit;
            transition: all 0.2s ease;
            position: relative;
        }

        .topic-btn:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        .topic-btn.active {
            background: #1C7EB5;
            color: white;
            border-left: 3px solid white;
            font-weight: 600;
        }

        .category-badge {
            display: inline-block;
            font-size: 0.65rem;
            padding: 2px 6px;
            border-radius: 8px;
            margin-left: 8px;
            font-weight: 500;
            vertical-align: middle;
            background: #5a6e7a;
            color: white;
        }

        .content {
            flex: 1;
            background: white;
            padding: 2rem 2.2rem;
            overflow-y: auto;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(28, 88, 122, 0.15);
        }

        .example-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 20px;
            color: #0B2B3F;
            letter-spacing: -0.02em;
            border-left: 4px solid #1C7EB5;
            padding-left: 20px;
        }

        .description {
            margin: 20px 0;
            line-height: 1.7;
            color: #2c4a6e;
            font-size: 1.2rem;
            padding: 0 4px;
            white-space: pre-wrap;
        }

        .language-selector {
            margin: 20px 0;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            padding: 0 4px;
        }

        .lang-btn {
            padding: 10px 20px;
            background: #eef2f8;
            border: 2px solid #dce5ec;
            border-radius: 12px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s ease;
            color: #2c4a6e;
        }

        .lang-btn:hover {
            background: #1C7EB5;
            border-color: #1C7EB5;
            color: white;
            transform: translateY(-2px);
        }

        .lang-btn.active {
            background: #0B2B3F;
            border-color: #1C7EB5;
            color: white;
        }

        .lang-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            filter: grayscale(0.2);
        }

        .lang-btn.disabled:hover {
            transform: none;
            background: #eef2f8;
            border-color: #dce5ec;
            color: #2c4a6e;
        }

        .example-code {
            background: #1e2a3a;
            border-left: 4px solid #1C7EB5;
            padding: 20px;
            margin: 20px 0;
            font-family: 'Courier New', 'Fira Code', monospace;
            font-size: 0.95rem;
            white-space: pre-wrap;
            overflow-x: auto;
            border-radius: 12px;
            color: #e2e8f0;
            line-height: 1.5;
        }

        .explanation-section {
            margin: 24px 0 20px 0;
            padding: 20px 24px;
            background: #f8fafd;
            border-radius: 16px;
            border-left: 4px solid #1C7EB5;
        }

        .explanation-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0B2B3F;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .explanation-title:before {
            content: "📖";
            font-size: 1.1rem;
        }

        .explanation-text {
            font-size: 1rem;
            line-height: 1.7;
            color: #2c4a6e;
            white-space: pre-wrap;
        }

        .toggle-buttons {
            margin: 24px 0;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .toggle-btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        .toggle-btn.insecure {
            background: #dc3545;
            color: white;
            box-shadow: 0 2px 6px rgba(220, 53, 69, 0.3);
        }

        .toggle-btn.secure {
            background: #28a745;
            color: white;
            box-shadow: 0 2px 6px rgba(40, 167, 69, 0.3);
        }

        .toggle-btn:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }

        .toggle-btn:active {
            transform: translateY(0);
        }

        .badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

        .badge.insecure {
            background: #dc3545;
            color: white;
        }

        .badge.secure {
            background: #28a745;
            color: white;
        }

        .empty-state {
            color: #7f8c9a;
            text-align: center;
            margin-top: 60px;
            font-size: 1rem;
        }

        .sidebar::-webkit-scrollbar {
            width: 5px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: #1c4057;
            border-radius: 10px;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: #3b9bd5;
            border-radius: 10px;
        }

        .content::-webkit-scrollbar {
            width: 6px;
        }
        .content::-webkit-scrollbar-track {
            background: #e2e8f0;
            border-radius: 10px;
        }
        .content::-webkit-scrollbar-thumb {
            background: #9bbdd2;
            border-radius: 10px;
        }

        @media (max-width: 780px) {
            .vulnerability-app {
                flex-direction: column;
                padding: 1rem;
                gap: 1rem;
            }
            .sidebar {
                width: 100%;
                border-radius: 1.6rem;
                padding: 1.2rem;
            }
            .content {
                padding: 1.5rem;
            }
            .example-title {
                font-size: 1.5rem;
            }
            .description {
                font-size: 1rem;
            }
            .toggle-buttons {
                gap: 8px;
            }
            .toggle-btn {
                padding: 8px 16px;
                font-size: 0.85rem;
            }
            .explanation-section {
                padding: 16px 20px;
            }
            .lang-btn {
                padding: 6px 12px;
                font-size: 0.8rem;
            }
            .category-badge {
                font-size: 0.55rem;
                padding: 2px 4px;
            }
        }

        @media (max-width: 480px) {
            .example-code {
                font-size: 0.7rem;
                padding: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="vulnerability-app">
        <div class="sidebar">
            <a href="/" class="home-button">
                <span class="home-icon">🏠</span>
                <span>← Back to Home</span>
            </a>
            <h2>Vulnerability Library</h2>

            <div class="search-container">
                <span class="search-icon">🔍</span>
                <input type="text" id="searchInput" class="search-input" placeholder="Search vulnerabilities...">
                <button id="clearSearch" class="clear-search">✕</button>
            </div>

            <div id="topicList"></div>
        </div>

        <div class="content">
            <div id="main">
                <div class="example-title">📚 Select a vulnerability</div>
                <div class="description">Choose a vulnerability from the sidebar, then select a programming language and toggle between insecure and secure examples.</div>
            </div>
        </div>
    </div>

    <script>
        let vulnerabilities = <%- JSON.stringify(locals.vulnerabilities || []).replace(/<\//g, '<\\/') %>;

        console.log('Vulnerabilities loaded:', vulnerabilities);

        let currentVuln = null;
        let currentSecurityType = 'insecure';
        let currentLanguage = 'php';

        function getColorForCategory(category) {
            if (!category) return '#5a6e7a';
            let hash = 0;
            for (let i = 0; i < category.length; i++) {
                hash = ((hash << 5) - hash) + category.charCodeAt(i);
                hash = hash & hash;
            }
            const hue = Math.abs(hash % 360);
            return `hsl(${hue}, 55%, 45%)`;
        }

        function hasLanguageExamples(language) {
            if (!currentVuln) return false;
            const insecureField = `insecure_${language}`;
            const secureField = `secure_${language}`;
            return (currentVuln[insecureField] && currentVuln[insecureField].trim() !== '') ||
                   (currentVuln[secureField] && currentVuln[secureField].trim() !== '');
        }

        function getFirstAvailableLanguage() {
            if (hasLanguageExamples('php')) return 'php';
            if (hasLanguageExamples('python')) return 'python';
            if (hasLanguageExamples('node')) return 'node';
            return null;
        }

        function getExampleText() {
            if (!currentVuln) return '';
            const fieldName = `${currentSecurityType}_${currentLanguage}`;
            const example = currentVuln[fieldName];
            if (example && example.trim() !== '') {
                return example;
            }
            return 'No example available for this language.';
        }

        // SAFE: Use textContent for EVERYTHING - no innerHTML for user data
        function displayCurrentExample() {
            if (!currentVuln) return;

            const exampleText = getExampleText();
            const hasPhp = hasLanguageExamples('php');
            const hasPython = hasLanguageExamples('python');
            const hasNode = hasLanguageExamples('node');

            // Clear the main container
            const main = document.getElementById('main');
            main.innerHTML = '';

            // Badge
            const badge = document.createElement('div');
            badge.className = `badge ${currentSecurityType === 'insecure' ? 'insecure' : 'secure'}`;
            badge.textContent = currentSecurityType === 'insecure' ? '⚠️ INSECURE EXAMPLE' : '✅ SECURE EXAMPLE';
            main.appendChild(badge);

            // Title
            const title = document.createElement('div');
            title.className = 'example-title';
            title.textContent = currentVuln.name || 'Vulnerability';
            main.appendChild(title);

            // Description - using textContent for safety
            const desc = document.createElement('div');
            desc.className = 'description';
            desc.textContent = currentVuln.description || 'No description available';
            main.appendChild(desc);

            // Language selector
            if (hasPhp || hasPython || hasNode) {
                const langDiv = document.createElement('div');
                langDiv.className = 'language-selector';

                if (hasPhp) {
                    const phpBtn = document.createElement('button');
                    phpBtn.className = `lang-btn ${currentLanguage === 'php' ? 'active' : ''}`;
                    phpBtn.textContent = '🐘 PHP';
                    phpBtn.onclick = () => setLanguage('php');
                    langDiv.appendChild(phpBtn);
                }

                if (hasPython) {
                    const pyBtn = document.createElement('button');
                    pyBtn.className = `lang-btn ${currentLanguage === 'python' ? 'active' : ''}`;
                    pyBtn.textContent = '🐍 Python';
                    pyBtn.onclick = () => setLanguage('python');
                    langDiv.appendChild(pyBtn);
                }

                if (hasNode) {
                    const nodeBtn = document.createElement('button');
                    nodeBtn.className = `lang-btn ${currentLanguage === 'node' ? 'active' : ''}`;
                    nodeBtn.textContent = '📦 Node.js';
                    nodeBtn.onclick = () => setLanguage('node');
                    langDiv.appendChild(nodeBtn);
                }

                main.appendChild(langDiv);
            } else {
                const noCodeMsg = document.createElement('div');
                noCodeMsg.className = 'description';
                noCodeMsg.style.color = '#c0392b';
                noCodeMsg.textContent = 'No code examples available for this vulnerability.';
                main.appendChild(noCodeMsg);
            }

            // Toggle buttons
            const toggleDiv = document.createElement('div');
            toggleDiv.className = 'toggle-buttons';

            const insecureBtn = document.createElement('button');
            insecureBtn.className = 'toggle-btn insecure';
            insecureBtn.textContent = '🔓 Show Insecure Example';
            insecureBtn.onclick = () => setSecurityType('insecure');
            toggleDiv.appendChild(insecureBtn);

            const secureBtn = document.createElement('button');
            secureBtn.className = 'toggle-btn secure';
            secureBtn.textContent = '🔒 Show Secure Example';
            secureBtn.onclick = () => setSecurityType('secure');
            toggleDiv.appendChild(secureBtn);

            main.appendChild(toggleDiv);

            // Code example - using textContent, NO HTML ESCAPING NEEDED
            const codeBlock = document.createElement('div');
            codeBlock.className = 'example-code';
            codeBlock.textContent = exampleText;
            main.appendChild(codeBlock);

            // Explanation - using textContent
            if (currentVuln.explanation && currentVuln.explanation.trim() !== '') {
                const explSection = document.createElement('div');
                explSection.className = 'explanation-section';

                const explTitle = document.createElement('div');
                explTitle.className = 'explanation-title';
                explTitle.textContent = 'Code Explanation';
                explSection.appendChild(explTitle);

                const explText = document.createElement('div');
                explText.className = 'explanation-text';
                explText.textContent = currentVuln.explanation;
                explSection.appendChild(explText);

                main.appendChild(explSection);
            }
        }

        function setLanguage(language) {
            if (hasLanguageExamples(language)) {
                currentLanguage = language;
                displayCurrentExample();
            }
        }

        function setSecurityType(type) {
            currentSecurityType = type;
            displayCurrentExample();
        }

        function showVulnerability(vuln) {
            if (!vuln) return;
            currentVuln = vuln;
            currentSecurityType = 'insecure';
            const firstLang = getFirstAvailableLanguage();
            if (firstLang) {
                currentLanguage = firstLang;
            }
            displayCurrentExample();

            document.querySelectorAll('.topic-btn').forEach(btn => {
                btn.classList.remove('active');
                if (parseInt(btn.dataset.id) === vuln.id) {
                    btn.classList.add('active');
                }
            });
        }

        function createVulnerabilityButton(vuln) {
            const btn = document.createElement('button');
            btn.className = 'topic-btn';

            const titleSpan = document.createElement('span');
            titleSpan.textContent = vuln.name || 'Untitled';
            btn.appendChild(titleSpan);

            if (vuln.category && vuln.category.trim() !== '') {
                const badge = document.createElement('span');
                badge.className = 'category-badge';
                badge.textContent = vuln.category;
                badge.style.backgroundColor = getColorForCategory(vuln.category);
                btn.appendChild(badge);
            }

            btn.setAttribute('data-id', vuln.id);
            btn.addEventListener('click', (function(v) {
                return function() { showVulnerability(v); };
            })(vuln));

            return btn;
        }

        function buildSidebar(searchTerm = '') {
            const container = document.getElementById('topicList');

            if (!vulnerabilities || vulnerabilities.length === 0) {
                container.innerHTML = '<div style="color:#aac7df; padding:1rem; text-align:center;">📭 No vulnerabilities found</div>';
                return;
            }

            let filteredVulnerabilities = vulnerabilities;
            if (searchTerm && searchTerm.trim() !== '') {
                const term = searchTerm.toLowerCase().trim();
                filteredVulnerabilities = vulnerabilities.filter(vuln =>
                    vuln.name && vuln.name.toLowerCase().includes(term)
                );
            }

            if (filteredVulnerabilities.length === 0) {
                container.innerHTML = '<div class="no-results">No matching vulnerabilities found</div>';
                return;
            }

            container.innerHTML = '';

            if (searchTerm && searchTerm.trim() !== '') {
                for (let i = 0; i < filteredVulnerabilities.length; i++) {
                    container.appendChild(createVulnerabilityButton(filteredVulnerabilities[i]));
                }
                if (filteredVulnerabilities.length > 0) {
                    showVulnerability(filteredVulnerabilities[0]);
                }
                return;
            }

            const groupedVulnerabilities = {};
            for (let i = 0; i < filteredVulnerabilities.length; i++) {
                const vuln = filteredVulnerabilities[i];
                const category = vuln.category || 'Uncategorized';
                if (!groupedVulnerabilities[category]) {
                    groupedVulnerabilities[category] = [];
                }
                groupedVulnerabilities[category].push(vuln);
            }

            const sortedCategories = Object.keys(groupedVulnerabilities).sort();
            let firstShown = false;

            for (const categoryName of sortedCategories) {
                const vulnsInCat = groupedVulnerabilities[categoryName];
                const categoryDiv = document.createElement('div');
                categoryDiv.className = 'category-section';

                const categoryTitle = document.createElement('div');
                categoryTitle.className = 'category-title';
                categoryTitle.textContent = categoryName;
                categoryDiv.appendChild(categoryTitle);

                for (const vuln of vulnsInCat) {
                    categoryDiv.appendChild(createVulnerabilityButton(vuln));
                }

                container.appendChild(categoryDiv);

                if (!firstShown && vulnsInCat.length > 0) {
                    showVulnerability(vulnsInCat[0]);
                    firstShown = true;
                }
            }
        }

        window.setLanguage = setLanguage;
        window.setSecurityType = setSecurityType;

        buildSidebar();

        const searchInput = document.getElementById('searchInput');
        const clearButton = document.getElementById('clearSearch');

        searchInput.addEventListener('input', function(e) {
            const searchTerm = e.target.value;
            buildSidebar(searchTerm);
            clearButton.style.display = searchTerm ? 'block' : 'none';
        });

        clearButton.addEventListener('click', function() {
            searchInput.value = '';
            buildSidebar('');
            clearButton.style.display = 'none';
            searchInput.focus();
        });
    </script>
</body>
</html>
