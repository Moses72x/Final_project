<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>SecureCodeHub — Vulnerability Examples</title>
    <style>
        /* Reset default browser margins and box sizing for consistent rendering */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Body styling with gradient background matching SecureCodeHub theme */
        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            background: linear-gradient(145deg, #f0f4f8 0%, #e6edf4 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Main layout container using flexbox for sidebar and content */
        .vulnerability-app {
            display: flex;
            max-width: 1600px;
            width: 100%;
            flex: 1;
        }

        /* Sidebar styling matching Topics page with deep blue/black theme */
        .sidebar {
            width: 300px;
            background: #0B2B3F;
            color: white;
            padding: 28px 20px;
            overflow-y: auto;
            box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.15);
            border: 1px solid rgba(28, 126, 181, 0.35);
            display: flex;
            flex-direction: column;
        }

        /* Home button positioned at top of sidebar for navigation */
        .home-button {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 16px;
            margin-bottom: 24px;
            background: #1a4b6e;
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            width: 100%;
        }

        /* Home button hover effect with slide animation */
        .home-button:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        /* Home button active/press effect */
        .home-button:active {
            transform: translateX(2px);
        }

        /* Home icon styling */
        .home-icon {
            font-size: 1.2rem;
        }

        /* Sidebar title with warning icon and blue bottom border */
        .sidebar h2 {
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 2px solid #1C7EB5;
            letter-spacing: -0.3px;
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Warning icon before sidebar title */
        .sidebar h2:before {
            content: "⚠️";
            font-size: 1.4rem;
        }

        /* Search bar styling */
        .search-container {
            margin-bottom: 20px;
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1rem;
            opacity: 0.7;
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            padding: 10px 12px 10px 36px;
            background: #1a4b6e;
            border: 1px solid #2c7cb6;
            border-radius: 12px;
            color: white;
            font-size: 0.9rem;
            font-family: inherit;
            outline: none;
            transition: all 0.2s ease;
        }

        .search-input::placeholder {
            color: #a0c4e0;
            opacity: 0.7;
        }

        .search-input:focus {
            border-color: #1C7EB5;
            background: #2c7cb6;
            box-shadow: 0 0 0 2px rgba(28, 126, 181, 0.3);
        }

        .clear-search {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            font-size: 1rem;
            padding: 0;
            display: none;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        .clear-search:hover {
            opacity: 1;
        }

        /* No results message */
        .no-results {
            text-align: center;
            color: #a0c4e0;
            padding: 20px;
            font-size: 0.9rem;
            font-style: italic;
        }

        /* Category section styling */
        .category-section {
            margin-bottom: 20px;
        }

        .category-title {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #8ab3cf;
            margin: 15px 0 8px 0;
            padding-left: 8px;
        }

        .category-title:first-of-type {
            margin-top: 0;
        }

        /* Vulnerability selection button styling */
        .topic-btn {
            width: 100%;
            padding: 12px 16px;
            margin-bottom: 6px;
            background: #1a4b6e;
            color: #f0f7fc;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            text-align: left;
            font-size: 0.95rem;
            font-weight: 500;
            font-family: inherit;
            transition: all 0.2s ease;
            position: relative;
        }

        /* Button hover effect with slide */
        .topic-btn:hover {
            background: #2c7cb6;
            transform: translateX(4px);
        }

        /* Active/selected vulnerability button styling */
        .topic-btn.active {
            background: #1C7EB5;
            color: white;
            border-left: 3px solid white;
            font-weight: 600;
        }

        /* Category badge inside topic button */
        .category-badge {
            display: inline-block;
            font-size: 0.65rem;
            padding: 2px 6px;
            border-radius: 8px;
            margin-left: 8px;
            font-weight: 500;
            vertical-align: middle;
            background: #5a6e7a;
            color: white;
        }

        /* Main content area - white card style */
        .content {
            flex: 1;
            background: white;
            padding: 2rem 2.2rem;
            overflow-y: auto;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(28, 88, 122, 0.15);
        }

        /* Vulnerability title styling with blue left border */
        .example-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 20px;
            color: #0B2B3F;
            letter-spacing: -0.02em;
            border-left: 4px solid #1C7EB5;
            padding-left: 20px;
        }

        /* Vulnerability description text */
        .description {
            margin: 20px 0;
            line-height: 1.7;
            color: #2c4a6e;
            font-size: 1.2rem;
            padding: 0 4px;
        }

        /* Language selector buttons */
        .language-selector {
            margin: 20px 0;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            padding: 0 4px;
        }

        .lang-btn {
            padding: 10px 20px;
            background: #eef2f8;
            border: 2px solid #dce5ec;
            border-radius: 12px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s ease;
            color: #2c4a6e;
        }

        .lang-btn:hover {
            background: #1C7EB5;
            border-color: #1C7EB5;
            color: white;
            transform: translateY(-2px);
        }

        .lang-btn.active {
            background: #0B2B3F;
            border-color: #1C7EB5;
            color: white;
        }

        .lang-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            filter: grayscale(0.2);
        }

        .lang-btn.disabled:hover {
            transform: none;
            background: #eef2f8;
            border-color: #dce5ec;
            color: #2c4a6e;
        }

        /* Code block styling with dark background and blue accent */
        .example-code {
            background: #1e2a3a;
            border-left: 4px solid #1C7EB5;
            padding: 20px;
            margin: 20px 0;
            font-family: 'Courier New', 'Fira Code', monospace;
            font-size: 0.95rem;
            white-space: pre-wrap;
            overflow-x: auto;
            border-radius: 12px;
            color: #e2e8f0;
            line-height: 1.5;
        }

        /* Explanation section container below code example */
        .explanation-section {
            margin: 24px 0 20px 0;
            padding: 20px 24px;
            background: #f8fafd;
            border-radius: 16px;
            border-left: 4px solid #1C7EB5;
        }

        /* Explanation section title with book icon */
        .explanation-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0B2B3F;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Book icon before explanation title */
        .explanation-title:before {
            content: "📖";
            font-size: 1.1rem;
        }

        /* Explanation text content */
        .explanation-text {
            font-size: 1rem;
            line-height: 1.7;
            color: #2c4a6e;
        }

        /* Container for insecure/secure toggle buttons */
        .toggle-buttons {
            margin: 24px 0;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        /* Toggle button base styling */
        .toggle-btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        /* Red button for insecure examples */
        .toggle-btn.insecure {
            background: #dc3545;
            color: white;
            box-shadow: 0 2px 6px rgba(220, 53, 69, 0.3);
        }

        /* Green button for secure examples */
        .toggle-btn.secure {
            background: #28a745;
            color: white;
            box-shadow: 0 2px 6px rgba(40, 167, 69, 0.3);
        }

        /* Hover effect for toggle buttons */
        .toggle-btn:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }

        /* Active/press effect for toggle buttons */
        .toggle-btn:active {
            transform: translateY(0);
        }

        /* Badge styling for example type indicator */
        .badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

        /* Red badge for insecure examples */
        .badge.insecure {
            background: #dc3545;
            color: white;
        }

        /* Green badge for secure examples */
        .badge.secure {
            background: #28a745;
            color: white;
        }

        /* Empty state message styling */
        .empty-state {
            color: #7f8c9a;
            text-align: center;
            margin-top: 60px;
            font-size: 1rem;
        }

        /* Custom scrollbar for sidebar */
        .sidebar::-webkit-scrollbar {
            width: 5px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: #1c4057;
            border-radius: 10px;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: #3b9bd5;
            border-radius: 10px;
        }

        /* Custom scrollbar for content area */
        .content::-webkit-scrollbar {
            width: 6px;
        }
        .content::-webkit-scrollbar-track {
            background: #e2e8f0;
            border-radius: 10px;
        }
        .content::-webkit-scrollbar-thumb {
            background: #9bbdd2;
            border-radius: 10px;
        }

        /* Responsive adjustments for tablets */
        @media (max-width: 780px) {
            .vulnerability-app {
                flex-direction: column;
                padding: 1rem;
                gap: 1rem;
            }
            .sidebar {
                width: 100%;
                border-radius: 1.6rem;
                padding: 1.2rem;
            }
            .content {
                padding: 1.5rem;
            }
            .example-title {
                font-size: 1.5rem;
            }
            .description {
                font-size: 1rem;
            }
            .toggle-buttons {
                gap: 8px;
            }
            .toggle-btn {
                padding: 8px 16px;
                font-size: 0.85rem;
            }
            .explanation-section {
                padding: 16px 20px;
            }
            .lang-btn {
                padding: 6px 12px;
                font-size: 0.8rem;
            }
            .category-badge {
                font-size: 0.55rem;
                padding: 2px 4px;
            }
        }

        /* Responsive adjustments for mobile devices */
        @media (max-width: 480px) {
            .example-code {
                font-size: 0.7rem;
                padding: 12px;
            }
        }
    </style>
</head>
<body>
    <div class="vulnerability-app">
        <!-- Sidebar with home button and vulnerability list -->
        <div class="sidebar">
            <a href="/" class="home-button">
                <span class="home-icon">🏠</span>
                <span>← Back to Home</span>
            </a>
            <h2>Vulnerability Library</h2>

            <!-- Search bar -->
            <div class="search-container">
                <span class="search-icon">🔍</span>
                <input type="text" id="searchInput" class="search-input" placeholder="Search vulnerabilities...">
                <button id="clearSearch" class="clear-search">✕</button>
            </div>

            <div id="topicList"></div>
        </div>

        <!-- Main content area where vulnerability details are displayed -->
        <div class="content">
            <div id="main">
                <div class="example-title">📚 Select a vulnerability</div>
                <div class="description">Choose a vulnerability from the sidebar, then select a programming language and toggle between insecure and secure examples.</div>
            </div>
        </div>
    </div>

    <script>
        // Array to store vulnerabilities fetched from the server (EJS template)
        let vulnerabilities = <%- JSON.stringify(locals.vulnerabilities || []) %>;

        // Debug log to verify vulnerabilities data in browser console
        console.log('Vulnerabilities loaded:', vulnerabilities);

        // State variables for current vulnerability, example type, and language
        let currentVuln = null;           // Currently selected vulnerability object
        let currentSecurityType = 'insecure'; // 'insecure' or 'secure'
        let currentLanguage = 'php';       // 'php', 'python', or 'node'

        /**
         * Escapes HTML special characters to prevent XSS attacks
         * @param {string} str - The string to escape
         * @returns {string} Escaped string safe for HTML insertion
         */
        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        /**
         * Generates a consistent color for a given category string
         * @param {string} category - The vulnerability category
         * @returns {string} HSL color value
         */
        function getColorForCategory(category) {
            if (!category) return '#5a6e7a';

            // Generate a hash from the category string
            let hash = 0;
            for (let i = 0; i < category.length; i++) {
                hash = ((hash << 5) - hash) + category.charCodeAt(i);
                hash = hash & hash; // Convert to 32-bit integer
            }

            // Use the hash to generate a hue between 0 and 360
            const hue = Math.abs(hash % 360);
            return `hsl(${hue}, 55%, 45%)`;
        }

        /**
         * Checks if a language has example code for the current vulnerability
         * @param {string} language - The language to check ('php', 'python', or 'node')
         * @returns {boolean} True if at least one example (insecure or secure) exists
         */
        function hasLanguageExamples(language) {
            if (!currentVuln) return false;

            const insecureField = `insecure_${language}`;
            const secureField = `secure_${language}`;

            return (currentVuln[insecureField] && currentVuln[insecureField].trim() !== '') ||
                   (currentVuln[secureField] && currentVuln[secureField].trim() !== '');
        }

        /**
         * Gets the first available language with examples
         * @returns {string} The first language that has examples
         */
        function getFirstAvailableLanguage() {
            if (hasLanguageExamples('php')) return 'php';
            if (hasLanguageExamples('python')) return 'python';
            if (hasLanguageExamples('node')) return 'node';
            return null;
        }

        /**
         * Gets the example text based on current security type and language
         * @returns {string} The example code
         */
        function getExampleText() {
            if (!currentVuln) return '';

            const fieldName = `${currentSecurityType}_${currentLanguage}`;
            const example = currentVuln[fieldName];

            if (example && example.trim() !== '') {
                return example;
            }

            // If no example for current language, try to find any available language
            if (currentLanguage === 'php' && hasLanguageExamples('python')) {
                return '⚠️ No PHP example available. Please try the Python example above.';
            } else if (currentLanguage === 'php' && hasLanguageExamples('node')) {
                return '⚠️ No PHP example available. Please try the Node.js example above.';
            } else if (currentLanguage === 'python' && hasLanguageExamples('php')) {
                return '⚠️ No Python example available. Please try the PHP example above.';
            } else if (currentLanguage === 'python' && hasLanguageExamples('node')) {
                return '⚠️ No Python example available. Please try the Node.js example above.';
            } else if (currentLanguage === 'node' && hasLanguageExamples('php')) {
                return '⚠️ No Node.js example available. Please try the PHP example above.';
            } else if (currentLanguage === 'node' && hasLanguageExamples('python')) {
                return '⚠️ No Node.js example available. Please try the Python example above.';
            }

            return 'No example available for this vulnerability.';
        }

        /**
         * Displays the current vulnerability example in the main content area
         * Shows badge, title, description, language buttons, toggle buttons, code example, and explanation
         */
        function displayCurrentExample() {
            if (!currentVuln) return;

            // Get the appropriate example text
            const exampleText = getExampleText();

            // Set badge text and styling based on security type
            const badgeText = currentSecurityType === 'insecure' ? '⚠️ INSECURE EXAMPLE' : '✅ SECURE EXAMPLE';
            const badgeClass = currentSecurityType === 'insecure' ? 'insecure' : 'secure';

            // Check which languages have examples
            const hasPhp = hasLanguageExamples('php');
            const hasPython = hasLanguageExamples('python');
            const hasNode = hasLanguageExamples('node');

            // Set active class for language buttons
            const phpActive = (currentLanguage === 'php' && hasPhp) ? 'active' : '';
            const pythonActive = (currentLanguage === 'python' && hasPython) ? 'active' : '';
            const nodeActive = (currentLanguage === 'node' && hasNode) ? 'active' : '';

            // Set disabled class for language buttons without examples
            const phpDisabled = !hasPhp ? 'disabled' : '';
            const pythonDisabled = !hasPython ? 'disabled' : '';
            const nodeDisabled = !hasNode ? 'disabled' : '';

            // Build HTML content
            let html = `
                <div class="badge ${badgeClass}">${badgeText}</div>
                <div class="example-title">${escapeHtml(currentVuln.name || 'Vulnerability')}</div>
                <div class="description">${escapeHtml(currentVuln.description || 'No description available')}</div>

                <!-- Language Selection Buttons - Only show if at least one language has examples -->
                ${(hasPhp || hasPython || hasNode) ? `
                <div class="language-selector">
                    ${hasPhp ? `<button class="lang-btn ${phpActive}" onclick="setLanguage('php')">PHP</button>` : `<button class="lang-btn disabled" disabled>🐘 PHP</button>`}
                    ${hasPython ? `<button class="lang-btn ${pythonActive}" onclick="setLanguage('python')">Python</button>` : `<button class="lang-btn disabled" disabled>🐍 Python</button>`}
                    ${hasNode ? `<button class="lang-btn ${nodeActive}" onclick="setLanguage('node')">Node.js</button>` : `<button class="lang-btn disabled" disabled>📦 Node.js</button>`}
                </div>
                ` : '<div class="description" style="color:#c0392b;">No code examples available for this vulnerability.</div>'}

                <!-- Security Type Toggle Buttons -->
                <div class="toggle-buttons">
                    <button class="toggle-btn insecure" onclick="setSecurityType('insecure')">🔓 Show Insecure Example</button>
                    <button class="toggle-btn secure" onclick="setSecurityType('secure')">🔒 Show Secure Example</button>
                </div>

                <!-- Code Example -->
                <div class="example-code">${escapeHtml(exampleText)}</div>
            `;

            // Add explanation section if explanation text exists in the database
            if (currentVuln.explanation && currentVuln.explanation.trim() !== '') {
                html += `
                    <div class="explanation-section">
                        <div class="explanation-title">Code Explanation</div>
                        <div class="explanation-text">${escapeHtml(currentVuln.explanation).replace(/\n/g, '<br>')}</div>
                    </div>
                `;
            }

            // Insert the generated HTML into the main content area
            document.getElementById('main').innerHTML = html;
        }

        /**
         * Switches between programming languages
         * @param {string} language - 'php', 'python', or 'node'
         */
        function setLanguage(language) {
            // Only switch if the language has examples
            if (hasLanguageExamples(language)) {
                currentLanguage = language;
                displayCurrentExample();
            }
        }

        /**
         * Switches between insecure and secure example views
         * @param {string} type - Either 'insecure' or 'secure'
         */
        function setSecurityType(type) {
            currentSecurityType = type;
            displayCurrentExample();
        }

        /**
         * Displays a selected vulnerability topic
         * @param {Object} vuln - The vulnerability object to display
         */
        function showVulnerability(vuln) {
            if (!vuln) return;
            currentVuln = vuln;
            currentSecurityType = 'insecure'; // Reset to insecure when changing topics

            // Reset to first available language
            const firstLang = getFirstAvailableLanguage();
            if (firstLang) {
                currentLanguage = firstLang;
            } else {
                currentLanguage = 'php';
            }

            displayCurrentExample();

            // Update active button state in sidebar
            document.querySelectorAll('.topic-btn').forEach(btn => {
                btn.classList.remove('active');
                if (parseInt(btn.dataset.id) === vuln.id) {
                    btn.classList.add('active');
                }
            });
        }

        /**
         * Creates a button element for a vulnerability
         * @param {Object} vuln - The vulnerability object
         * @returns {HTMLElement} Button element
         */
        function createVulnerabilityButton(vuln) {
            const btn = document.createElement('button');
            btn.className = 'topic-btn';

            // Add title text
            const titleSpan = document.createElement('span');
            titleSpan.textContent = vuln.name || 'Untitled';
            btn.appendChild(titleSpan);

            // Add category badge if category exists
            if (vuln.category) {
                const badge = document.createElement('span');
                badge.className = 'category-badge';
                badge.textContent = vuln.category;
                // Apply dynamic color based on the category string
                badge.style.backgroundColor = getColorForCategory(vuln.category);
                btn.appendChild(badge);
            }

            btn.setAttribute('data-id', vuln.id);

            // Add click event listener that displays the selected vulnerability
            btn.addEventListener('click', (function(v) {
                return function() { showVulnerability(v); };
            })(vuln));

            return btn;
        }

        /**
         * Builds the sidebar with clickable vulnerability buttons grouped by category based on search filter
         * @param {string} searchTerm - Optional term to filter vulnerabilities
         */
        function buildSidebar(searchTerm = '') {
            const container = document.getElementById('topicList');

            // Handle case when no vulnerabilities are available
            if (!vulnerabilities || vulnerabilities.length === 0) {
                container.innerHTML = '<div style="color:#aac7df; padding:1rem; text-align:center;">📭 No vulnerabilities found</div>';
                return;
            }

            // Filter vulnerabilities based on search term
            let filteredVulnerabilities = vulnerabilities;
            if (searchTerm && searchTerm.trim() !== '') {
                const term = searchTerm.toLowerCase().trim();
                filteredVulnerabilities = vulnerabilities.filter(vuln =>
                    vuln.name && vuln.name.toLowerCase().includes(term)
                );
            }

            // Handle no search results
            if (filteredVulnerabilities.length === 0) {
                container.innerHTML = '<div class="no-results">No matching vulnerabilities found</div>';
                return;
            }

            // Clear any existing content
            container.innerHTML = '';

            // If search is active, show flat list without categories
            if (searchTerm && searchTerm.trim() !== '') {
                for (let i = 0; i < filteredVulnerabilities.length; i++) {
                    const vuln = filteredVulnerabilities[i];
                    const btn = createVulnerabilityButton(vuln);
                    container.appendChild(btn);
                }
                if (filteredVulnerabilities.length > 0) {
                    showVulnerability(filteredVulnerabilities[0]);
                }
                return;
            }

            // Group vulnerabilities by category for categorized display
            const groupedVulnerabilities = {};

            // Group vulnerabilities by their category (use 'Uncategorized' for vulnerabilities without a category)
            for (let i = 0; i < filteredVulnerabilities.length; i++) {
                const vuln = filteredVulnerabilities[i];
                const category = vuln.category || 'Uncategorized';

                if (!groupedVulnerabilities[category]) {
                    groupedVulnerabilities[category] = [];
                }
                groupedVulnerabilities[category].push(vuln);
            }

            // Sort categories alphabetically
            const sortedCategories = Object.keys(groupedVulnerabilities).sort();

            // Create category sections
            let firstVulnerabilityShown = false;
            for (let categoryIndex = 0; categoryIndex < sortedCategories.length; categoryIndex++) {
                const categoryName = sortedCategories[categoryIndex];
                const vulnerabilitiesInCategory = groupedVulnerabilities[categoryName];

                // Add category title
                const categoryDiv = document.createElement('div');
                categoryDiv.className = 'category-section';

                const categoryTitle = document.createElement('div');
                categoryTitle.className = 'category-title';
                categoryTitle.textContent = categoryName;
                categoryDiv.appendChild(categoryTitle);

                // Add buttons for each vulnerability in this category
                for (let i = 0; i < vulnerabilitiesInCategory.length; i++) {
                    const vuln = vulnerabilitiesInCategory[i];
                    const btn = createVulnerabilityButton(vuln);
                    categoryDiv.appendChild(btn);
                }

                container.appendChild(categoryDiv);

                // Show the first vulnerability from the first category
                if (!firstVulnerabilityShown && vulnerabilitiesInCategory.length > 0) {
                    showVulnerability(vulnerabilitiesInCategory[0]);
                    firstVulnerabilityShown = true;
                }
            }
        }

        // Make functions globally accessible for inline onclick handlers
        window.setLanguage = setLanguage;
        window.setSecurityType = setSecurityType;

        // Initialize the page by building the sidebar
        buildSidebar();

        // Set up search functionality
        const searchInput = document.getElementById('searchInput');
        const clearButton = document.getElementById('clearSearch');

        // Handle search input
        searchInput.addEventListener('input', function(e) {
            const searchTerm = e.target.value;
            buildSidebar(searchTerm);

            // Show/hide clear button
            if (searchTerm) {
                clearButton.style.display = 'block';
            } else {
                clearButton.style.display = 'none';
            }
        });

        // Handle clear button click
        clearButton.addEventListener('click', function() {
            searchInput.value = '';
            buildSidebar('');
            clearButton.style.display = 'none';
            searchInput.focus();
        });
    </script>
</body>
</html>
